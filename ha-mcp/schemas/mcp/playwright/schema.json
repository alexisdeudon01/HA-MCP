{
  "$id": "urn:ha-mcp:mcp:playwright:v1",
  "mcp_id": "playwright",
  "name": "Playwright Browser",
  "version": "1.60.0",
  "description": "Contrôle d'un navigateur Chromium headless via Playwright. Permet le scraping web, l'interaction avec des pages dynamiques et les captures d'écran.",
  "category": "enrichissement",
  "tags": ["web", "scraping", "browser", "free"],

  "auth": { "required": false, "type": "none" },

  "probe": {
    "tool": "browser_navigate",
    "args": { "url": "about:blank" },
    "timeout_ms": 8000
  },

  "tools": [
    {
      "name": "browser_navigate",
      "description": "Navigate to a URL in the browser",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "The URL to navigate to" }
        },
        "required": ["url"]
      },
      "timeout_ms": 15000
    },
    {
      "name": "browser_snapshot",
      "description": "Returns an accessibility snapshot of the current page (DOM structure)",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filename": { "type": "string", "description": "Save snapshot to markdown file instead of returning it" },
          "depth":    { "type": "number", "description": "Limit depth of snapshot tree" }
        }
      },
      "timeout_ms": 10000
    },
    {
      "name": "browser_take_screenshot",
      "description": "Takes a screenshot of the current page",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type":     { "type": "string", "enum": ["png", "jpeg"], "default": "png" },
          "filename": { "type": "string", "description": "File name to save the screenshot" },
          "fullPage": { "type": "boolean", "description": "Capture full page", "default": false }
        }
      },
      "timeout_ms": 10000
    },
    {
      "name": "browser_click",
      "description": "Click on a web element",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "element": { "type": "string", "description": "Human-readable element description" },
          "ref":     { "type": "string", "description": "Exact target element ref from snapshot" }
        },
        "required": []
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_fill_form",
      "description": "Fill out a form with multiple fields",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name":  { "type": "string" },
                "type":  { "type": "string", "enum": ["textbox", "checkbox", "radio", "select", "combobox"] },
                "value": { "type": "string" }
              }
            }
          }
        },
        "required": ["fields"]
      },
      "timeout_ms": 10000
    },
    {
      "name": "browser_evaluate",
      "description": "Execute JavaScript in the browser context",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "function": { "type": "string", "description": "() => { /* code */ }" },
          "element":  { "type": "string", "description": "Element to pass as argument" }
        },
        "required": ["function"]
      },
      "timeout_ms": 10000
    },
    {
      "name": "browser_navigate_back",
      "description": "Navigate back in browser history",
      "capability": "web_scrape",
      "inputSchema": { "type": "object", "properties": {} },
      "timeout_ms": 5000
    },
    {
      "name": "browser_network_requests",
      "description": "Returns list of network requests made by the current page",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "static":      { "type": "boolean", "default": false },
          "requestBody": { "type": "boolean", "default": false }
        }
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_console_messages",
      "description": "Returns console messages from the browser",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "level": { "type": "string", "enum": ["error", "warning", "info", "log", "debug"], "default": "info" }
        }
      },
      "timeout_ms": 3000
    },
    {
      "name": "browser_close",
      "description": "Close the browser",
      "capability": "web_scrape",
      "inputSchema": { "type": "object", "properties": {} },
      "timeout_ms": 3000
    },
    {
      "name": "browser_resize",
      "description": "Resize the browser window",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "width":  { "type": "number" },
          "height": { "type": "number" }
        },
        "required": ["width", "height"]
      },
      "timeout_ms": 3000
    },
    {
      "name": "browser_type",
      "description": "Type text into a focused element",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "element": { "type": "string" },
          "ref":     { "type": "string" },
          "text":    { "type": "string", "description": "Text to type" }
        },
        "required": ["text"]
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_press_key",
      "description": "Press a keyboard key",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "Key name e.g. ArrowLeft, Enter, a" }
        },
        "required": ["key"]
      },
      "timeout_ms": 3000
    },
    {
      "name": "browser_hover",
      "description": "Hover over an element",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "element": { "type": "string" },
          "ref":     { "type": "string" }
        }
      },
      "timeout_ms": 3000
    },
    {
      "name": "browser_drag",
      "description": "Drag an element to a target",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "startElement": { "type": "string" },
          "startRef":     { "type": "string" },
          "endElement":   { "type": "string" },
          "endRef":       { "type": "string" }
        }
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_select_option",
      "description": "Select an option in a dropdown",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "element": { "type": "string" },
          "ref":     { "type": "string" },
          "values":  { "type": "array", "items": { "type": "string" } }
        },
        "required": ["values"]
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_handle_dialog",
      "description": "Handle browser dialogs (alert, confirm, prompt)",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "accept":     { "type": "boolean" },
          "promptText": { "type": "string" }
        },
        "required": ["accept"]
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_file_upload",
      "description": "Upload files via file chooser dialog",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "paths": { "type": "array", "items": { "type": "string" }, "description": "Absolute file paths to upload" }
        }
      },
      "timeout_ms": 10000
    },
    {
      "name": "browser_tabs",
      "description": "Manage browser tabs (list, new, close, select)",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["list", "new", "close", "select"] },
          "index":  { "type": "number" }
        },
        "required": ["action"]
      },
      "timeout_ms": 5000
    },
    {
      "name": "browser_wait_for",
      "description": "Wait for a condition (time, text appearing, or text disappearing)",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "time":     { "type": "number", "description": "Seconds to wait" },
          "text":     { "type": "string", "description": "Text to wait for" },
          "textGone": { "type": "string", "description": "Text to wait to disappear" }
        }
      },
      "timeout_ms": 30000
    },
    {
      "name": "browser_run_code",
      "description": "Run arbitrary Playwright code",
      "capability": "web_scrape",
      "inputSchema": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "description": "async (page) => { /* playwright code */ }" }
        },
        "required": ["code"]
      },
      "timeout_ms": 30000
    }
  ],

  "capabilities": ["enrichissement", "web_scrape"],
  "pipeline_stages": ["1.5", "2.1"],

  "error_handling": {
    "retry": true,
    "max_retries": 1,
    "retry_delay_ms": 2000,
    "on_failure": "degrade",
    "degradation_message": "Playwright indisponible — scraping web désactivé, DuckDuckGo uniquement"
  },

  "metadata": {
    "local": true,
    "free": true,
    "docs": "https://playwright.dev"
  }
}
